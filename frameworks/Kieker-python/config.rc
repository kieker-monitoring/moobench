# benchmark setup script

source ${MAIN_DIR}/config.rc

PYTHON=`which python3`

PIP=`which pip`
if [ ! -f "$PIP" ] ; then
	PIP=`which pip3`
fi

GIT=`which git`

RSCRIPT_PATH="${BASE_DIR}/../statistics.r"

DATA_DIR="${BASE_DIR}/data"

KIEKER_4_PYTHON_REPO_URL="https://github.com/kieker-monitoring/kieker-lang-pack-python.git"
KIEKER_4_PYTHON_DIR="${BASE_DIR}/kieker-lang-pack-python"
KIEKER_4_PYTHON_BRANCH="master"

RECEIVER_ARCHIVE="${MAIN_DIR}/tools/receiver/build/distributions/receiver.tar"

SUT_PYTHON_DIR="${MAIN_DIR}/tools/SuT-python"
MOOBENCH_BIN_PY="./benchmark.py"
